text = "Hello"

# WITHOUT :>48 — text starts at the left
print(f"Text: {text}")
# Output: Text: Hello

# WITH :>48 — text is pushed to the right side of a 48-character space
print(f"Text: {text:>48}")
# Output: Text:                                           Hello